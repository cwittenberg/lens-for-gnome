{
  "app-id": "org.gnome.Lens",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "appstream-compose": false,
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable",
    "org.freedesktop.Sdk.Extension.llvm20"
  ],
  "command": "gnome-lens-daemon",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--filesystem=home",
    "--filesystem=/usr/share/applications:ro",
    "--filesystem=/var/lib/flatpak/exports/share/applications:ro",
    "--filesystem=/var/lib/snapd/desktop/applications:ro",
    "--device=all"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin:/usr/lib/sdk/llvm20/bin",
    "append-ld-library-path": "/usr/lib/sdk/llvm20/lib",
    "env": {
      "LIBCLANG_PATH": "/usr/lib/sdk/llvm20/lib"
    }
  },
  "modules": [
    {
      "name": "pciutils",
      "no-autogen": true,
      "make-install-args": [
        "PREFIX=/app",
        "SBINDIR=/app/bin",
        "IDSDIR=/app/share"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://mj.ucw.cz/download/linux/pci/pciutils-3.10.0.tar.gz",
          "sha256": "7deabe38ae5fa88a96a8c4947975cf31c591506db546e9665a10dddbf350ead0"
        }
      ]
    },
    {
      "name": "leptonica",
      "buildsystem": "simple",
      "build-commands": [
        "rm -f CMakeCache.txt",
        "rm -rf flatpak-build",
        "mkdir flatpak-build",
        "cd flatpak-build && cmake .. -DCMAKE_INSTALL_PREFIX=/app -DCMAKE_BUILD_TYPE=Release -DBUILD_SHARED_LIBS=ON -DCMAKE_POLICY_VERSION_MINIMUM=3.5",
        "cd flatpak-build && make -j$(nproc)",
        "cd flatpak-build && make install"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/DanBloomberg/leptonica/releases/download/1.83.1/leptonica-1.83.1.tar.gz",
          "sha256": "8f18615e0743af7df7f50985c730dfcf0c93548073d1f56621e4156a8b54d3dd"
        }
      ]
    },
    {
      "name": "tesseract",
      "buildsystem": "simple",
      "build-commands": [
        "rm -f CMakeCache.txt",
        "rm -rf flatpak-build",
        "mkdir flatpak-build",
        "cd flatpak-build && cmake .. -DCMAKE_INSTALL_PREFIX=/app -DCMAKE_BUILD_TYPE=Release -DBUILD_TRAINING_TOOLS=OFF -DLeptonica_DIR=/app/lib/cmake/leptonica -DCMAKE_POLICY_VERSION_MINIMUM=3.5 -DTIFF_SUPPORT=OFF",
        "cd flatpak-build && make -j$(nproc)",
        "cd flatpak-build && make install"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/tesseract-ocr/tesseract/archive/refs/tags/5.3.3.tar.gz",
          "sha256": "dc4329f85f41191b2d813b71b528ba6047745813474e583ccce8795ff2ff5681"
        }
      ]
    },
    {
      "name": "poppler",
      "buildsystem": "simple",
      "build-commands": [
        "rm -f CMakeCache.txt",
        "rm -rf flatpak-build",
        "mkdir flatpak-build",
        "cd flatpak-build && cmake .. -DCMAKE_INSTALL_PREFIX=/app -DCMAKE_BUILD_TYPE=Release -DENABLE_UTILS=ON -DENABLE_CPP=OFF -DENABLE_GLIB=OFF -DENABLE_QT5=OFF -DENABLE_QT6=OFF -DENABLE_CMS=OFF -DENABLE_LIBOPENJPEG=none -DENABLE_BOOST=OFF",
        "cd flatpak-build && make -j$(nproc)",
        "cd flatpak-build && make install"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://poppler.freedesktop.org/poppler-23.11.0.tar.xz",
          "sha256": "f99cca6799cb9cb6c92fc1e0eb78547b611cb733750ab7cb047cb0e6c246539c"
        }
      ]
    },
    {
      "name": "ffmpeg",
      "buildsystem": "autotools",
      "config-opts": [
        "--disable-static",
        "--enable-shared",
        "--disable-doc",
        "--disable-programs",
        "--enable-ffmpeg",
        "--enable-ffprobe",
        "--disable-network",
        "--disable-ffplay",
        "--disable-nvenc",
        "--disable-ffnvcodec",
        "--disable-vulkan",
        "--disable-hwaccels"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://ffmpeg.org/releases/ffmpeg-6.1.tar.xz",
          "sha256": "488c76e57dd9b3bee901f71d5c95eaf1db4a5a31fe46a28654e837144207c270"
        }
      ]
    },
    {
      "name": "gnome-lens",
      "buildsystem": "simple",
      "build-options": {
        "build-args": [
          "--share=network"
        ],
        "env": {
          "CARGO_HOME": "/run/build/gnome-lens/cargo",
          "RUSTUP_HOME": "/run/build/gnome-lens/rustup"
        }
      },
      "build-commands": [
        "cargo build --release",
        "install -D -m 755 target/release/gnome-lens /app/bin/gnome-lens-daemon",
        "install -D -m 644 metadata/org.gnome.Lens.desktop /app/share/applications/org.gnome.Lens.desktop",
        "install -D -m 644 autostart/org.gnome.Lens.desktop /app/etc/xdg/autostart/org.gnome.Lens.desktop",
        "install -D -m 644 metadata/org.gnoem.Lens.appdata.xml /app/share/metainfo/org.gnome.Lens.appdata.xml",
        "install -D -m 644 metadata/org.gnome.Lens.icon.svg /app/share/icons/hicolor/scalable/apps/org.gnome.Lens.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}